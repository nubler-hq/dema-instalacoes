# Environment variables for dema-instalacoes
# Generated by @igniter-js/cli

# Logging level (debug, info, warn, error)
IGNITER_LOG_LEVEL=info

# Enable telemetry tracing
IGNITER_TELEMETRY_ENABLE_TRACING=true

# Enable telemetry metrics
IGNITER_TELEMETRY_ENABLE_METRICS=true

# Enable telemetry metrics
IGNITER_TELEMETRY_ENABLE_EVENTS=true

# Enable telemetry metrics
IGNITER_TELEMETRY_ENABLE_CLI_INTEGRATION=true

# PostgreSQL connection string
DATABASE_URL=postgresql://docker:docker@localhost:5432/docker

# Database host
DB_HOST=localhost

# Database port
DB_PORT=5432

# Database name
DB_NAME=docker

# Database user
DB_USER=docker

# Database password
DB_PASSWORD=docker

